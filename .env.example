# =================================================================
# NovaPay Environment Configuration Template
# Copy this file to .env and update with your actual values
# =================================================================

# 🗄️ Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=novapay_user
DB_PASSWORD=your_secure_database_password_here
DB_NAME=novapay

# 🔐 JWT Security Configuration
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here

# ⚡ Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# 🌍 Environment Setting
NODE_ENV=development

# 📱 Mobile Money APIs
# MTN MoMo (Nigeria)
MTN_MOMO_BASE_URL=https://api.mtn.com
MTN_MOMO_API_KEY=your_mtn_momo_api_key_here
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_momo_subscription_key_here
MTN_MOMO_ENVIRONMENT=sandbox

# 📱 M-Pesa (Kenya)
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_SHORTCODE=your_mpesa_shortcode_here
MPESA_PASSKEY=your_mpesa_passkey_here
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here

# 💳 Payment Gateways
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key_here

# 🏦 Banking & Verification
BVN_VERIFICATION_API_KEY=your_bvn_api_key_here
BVN_VERIFICATION_URL=https://api.bvn-verification.com

# 📱 SMS Provider
SMS_PROVIDER_API_KEY=your_sms_api_key_here
SMS_PROVIDER_URL=https://api.sms-provider.com

# 🌐 Application URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# 🔒 Security Settings
BCRYPT_SALT_ROUNDS=12
OTP_EXPIRY_MINUTES=5
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# 📁 File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# ⚡ Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 💰 Transaction Limits (in kobo - ₦1 = 100 kobo)
TIER_1_DAILY_LIMIT=50000
TIER_2_DAILY_LIMIT=1000000
TIER_3_DAILY_LIMIT=5000000

# 🎁 Referral Bonus (in kobo)
REFERRAL_BONUS_AMOUNT=10000
